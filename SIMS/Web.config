<?xml version="1.0" encoding="utf-8"?>
<!--
  Web.config for SIMS
  ─────────────────────────────────────────────────────────────
  1.  Update the "SimsDB" connection string to match your SQL Server instance.
  2.  The <authentication> section configures Forms-based login
      so that unauthenticated requests are bounced to Login.aspx.
  3.  Each role folder is locked down via <location> elements –
      the RoleGuard.cs helper enforces role-level access inside the pages.
-->
<configuration>

	<connectionStrings>
		<add name="SimsDB"
			 connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=SimsDB;Integrated Security=True;MultipleActiveResultSets=True;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>

	<appSettings>
		<!-- Used by RoleRedirectHelper – change if your folders differ -->
		<add key="AdminDashboard"    value="~/Admin/Dashboard.aspx" />
		<add key="LecturerDashboard" value="~/Lecturer/Dashboard.aspx" />
		<add key="StudentDashboard"  value="~/Student/Dashboard.aspx" />
	</appSettings>

	<system.web>

		<compilation debug="true" targetFramework="4.8" />
		<httpRuntime targetFramework="4.8" enableVersionHeader="false" />

		<!-- ── Forms authentication ── -->
		<authentication mode="Forms">
			<forms loginUrl="~/Login.aspx"
				   name=".SIMSAUTH"
				   timeout="60"
				   slidingExpiration="true"
				   protection="All"
				   cookieless="UseCookies"
				   requireSSL="false" />
			<!-- Set requireSSL="true" in production -->
		</authentication>

		<!-- Default: deny anonymous; individual folders override below -->
		<authorization>
			<deny users="?" />
		</authorization>

		<sessionState mode="InProc"
					  timeout="60"
					  cookieless="false"
					  regenerateExpiredSessionId="true" />

		<customErrors mode="RemoteOnly" defaultRedirect="~/Error.aspx">
			<error statusCode="403" redirect="~/Unauthorized.aspx" />
			<error statusCode="404" redirect="~/NotFound.aspx" />
		</customErrors>

		<pages controlRenderingCompatibilityVersion="4.0">
			<namespaces>
				<add namespace="SIMS.App_Code" />
			</namespaces>
		</pages>

	</system.web>

	<!-- ── Allow anonymous access to Login and shared assets ── -->
	<location path="Login.aspx">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
	</location>

	<location path="ForgotPassword.aspx">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
	</location>

	<location path="Content">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
	</location>

	<location path="Scripts">
		<system.web>
			<authorization>
				<allow users="*" />
			</authorization>
		</system.web>
	</location>

	<!-- ── Admin area: only the Admin role ── -->
	<location path="Admin">
		<system.web>
			<authorization>
				<allow roles="Admin" />
				<deny  users="*" />
			</authorization>
		</system.web>
	</location>

	<!-- ── Lecturer area: only the Lecturer role ── -->
	<location path="Lecturer">
		<system.web>
			<authorization>
				<allow roles="Lecturer" />
				<deny  users="*" />
			</authorization>
		</system.web>
	</location>

	<!-- ── Student area: only the Student role ── -->
	<location path="Student">
		<system.web>
			<authorization>
				<allow roles="Student" />
				<deny  users="*" />
			</authorization>
		</system.web>
	</location>

	<system.webServer>
		<validation validateIntegratedModeConfiguration="false" />
		<modules runAllManagedModulesForAllRequests="true" />
	</system.webServer>

</configuration>